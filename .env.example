# Google Calendar API 키 (한국 공휴일 자동 동기화용)
# 발급: Google Cloud Console → Calendar API 활성화 → 사용자 인증 정보 → API 키
VITE_GOOGLE_CALENDAR_API_KEY=your_api_key_here

# Supabase (동기화·인증용)
# 발급: Supabase 프로젝트 → Settings → API
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
